# n8n
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme

# OpenAI (used by n8n OpenAI node)
OPENAI_API_KEY=sk-...

# Slack incoming webhook
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Webhook Authentication
# Create a Header Auth credential in n8n with this header name and value
WEBHOOK_AUTH_HEADER=X-Webhook-Auth
WEBHOOK_AUTH_TOKEN=REPLACE_ME_WITH_YOUR_TOKEN

# CORS Configuration (required for local development)
# Set to the origin where your form is served
N8N_ALLOWED_CORS_ORIGINS=http://localhost:3000
