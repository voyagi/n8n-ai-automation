                }
              },
              {
                "type": "divider"
              },
              {
                "type": "context",
                "elements": [
                  {
                    "type": "mrkdwn",
                    "text": "Submitted: {{ $json.submittedAt }}"
                  }
                ]
              }
            ]
          }
        ],
        "otherOptions": {
