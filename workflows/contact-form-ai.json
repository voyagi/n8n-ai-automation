      }
    },
    {
      "parameters": {
        "authentication": "accessToken",
        "select": "channel",
        "channelId": {
          "__rl": true,
          "value": "C0123456789",
          "mode": "list"
        },
        "messageType": "attachment",
        "text": "New contact form submission from {{ $json.name }}",
        "attachments": [
          {
            "color": "={{ $json.category === 'sales' ? 'good' : ($json.category === 'support' ? 'danger' : 'warning') }}",
            "blocks": [
              {
